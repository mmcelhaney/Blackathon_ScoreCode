# ─── Supabase ─────────────────────────────────────────────────────
# From Supabase → Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co

# Public key (safe in the browser). Supabase shows this as either
# "Publishable key" (new) or "anon public" (legacy). Use whichever
# your project shows — the code accepts both.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=   # legacy name, also works

# Server-only. Bypasses RLS. NEVER expose to the browser.
# Supabase labels this either "Secret key" (new) or "service_role" (legacy).
SUPABASE_SECRET_KEY=
# SUPABASE_SERVICE_ROLE_KEY=       # legacy name, also works

# ─── App ──────────────────────────────────────────────────────────

# Shared admin password for /admin sign-in (pick something strong)
ADMIN_PASSWORD=

# Any random 32+ char string — signs admin session cookies + (future)
# submission edit magic links
SUBMISSION_EDIT_SECRET=

# Base URL (used in emails and redirects). Leave as localhost for dev.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
